# ════════════════════════════════════════════════════════════════
# Backend Environment Variables — Example
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════

# ─── Database ───────────────────────────────────────────────────
# SQLite for development (default):
DATABASE_URL=sqlite:///./timesheet.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://lightidea:yourpassword@localhost:5432/lightidea

# ─── PostgreSQL (docker-compose only) ───────────────────────────
POSTGRES_DB=lightidea
POSTGRES_USER=lightidea
POSTGRES_PASSWORD=changeme_strong_password_here

# ─── JWT ─────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=replace_me_with_a_128_char_random_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─── Google Gemini AI ────────────────────────────────────────────
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Encryption (at-rest field encryption) ─────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ─── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ─── Google OAuth (optional) ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft OAuth (optional) ─────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── OAuth Redirect Base URL ────────────────────────────────────
# Should be your frontend base URL
OAUTH_REDIRECT_BASE_URL=http://localhost:3000

# ─── Email (optional — for notification emails) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourcompany.com
